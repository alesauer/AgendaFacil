APP_ENV=development
SECRET_KEY=change-this-secret
JWT_EXPIRES_MINUTES=720

# PostgreSQL local desativado no backend (ignorado)
DATABASE_URL=

# Supabase HTTP client (recomendado quando rede bloqueia portas 5432/6543)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key
# SUPABASE_ONLY é forçado por código para true
SUPABASE_ONLY=true
BYPASS_PROXY_FOR_SUPABASE=false
DISABLE_SYSTEM_PROXY_FOR_SUPABASE=false
SUPABASE_HTTP_TIMEOUT_SECONDS=8
SUPABASE_TENANT_RETRIES=3

# Proxy corporativo (descomente e ajuste conforme sua rede)
# HTTP_PROXY=http://proxy.sua-rede:3128
# HTTPS_PROXY=http://proxy.sua-rede:3128
# NO_PROXY=localhost,127.0.0.1,::1

# Fallback local tenant slug for localhost development
DEFAULT_BARBEARIA_SLUG=demo

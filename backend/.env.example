
APP_ENV=development
SECRET_KEY=troque-por-uma-chave-forte-e-aleatoria
JWT_EXPIRES_MINUTES=720

# Supabase Postgres connection string
DATABASE_URL=

# Supabase HTTP client
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_ONLY=true
SUPABASE_NETWORK_MODE=auto
BYPASS_PROXY_FOR_SUPABASE=true
DISABLE_SYSTEM_PROXY_FOR_SUPABASE=false
SUPABASE_HTTP_TIMEOUT_SECONDS=8
SUPABASE_TENANT_RETRIES=3

# Proxy settings
PROXY_URL=http://proxy.almg.uucp:3128
PROXY_URL_HTTPS=https://proxy.almg.uucp:3128
HTTP_PROXY=http://proxy.almg.uucp:3128
HTTPS_PROXY=http://proxy.almg.uucp:3128
NO_PROXY=gac.almg.uucp,localhost,127.0.0.1,::1,wsl.localhost

# --- WhatsApp (Evolution) ---
EVOLUTION_API_BASE_URL=http://your-evolution-host:8082
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_API_KEY_HEADER=apikey
EVOLUTION_INSTANCE=your-instance-name
EVOLUTION_SEND_TEXT_PATH=/message/sendText/{instance}
EVOLUTION_HTTP_TIMEOUT_SECONDS=10

# --- Email (Resend) ---
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=your-resend-api-key
RESEND_HTTP_TIMEOUT_SECONDS=10
EMAIL_FROM_ADDRESS=no-reply@yourdomain.com
EMAIL_FROM_NAME=AgendaFácil

#Master
MASTER_LOGIN=master
MASTER_PASSWORD=admin123
MASTER_NAME=Master SaaS


# Fallback local tenant slug for localhost development
DEFAULT_BARBEARIA_SLUG=demo
# Payment Provider (Asaas é o único gateway suportado)
PAYMENT_PROVIDER=asaas

# Asaas
ASAAS_API_KEY=your-asaas-api-key
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=change-me-asaas-webhook-token
ASAAS_WEBHOOK_BARBEARIA_SLUG=demo
ASAAS_USE_PROXY=false
ASAAS_BILLING_TYPE=UNDEFINED
ASAAS_YEARLY_SPLIT_ENABLED=true
ASAAS_YEARLY_INSTALLMENT_COUNT=12
ASAAS_SANDBOX_CUSTOMER_EMAIL=test_customer@email.com
ASAAS_SANDBOX_CUSTOMER_NAME=Cliente Sandbox AgendaFacil
ASAAS_SANDBOX_CUSTOMER_PHONE=
ASAAS_SANDBOX_CUSTOMER_CPF_CNPJ=